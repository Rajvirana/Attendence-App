# Server (Render sets PORT)
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/attendance?retryWrites=true&w=majority

JWT_SECRET=use-a-long-random-string-in-production

# Comma-separated origins (no trailing slash). Local dev:
CLIENT_URL=http://localhost:5173
# Production on Render — include your Vercel URL(s), e.g.:
# CLIENT_URL=https://attendenceapp-git-main-rajvi-ranas-projects.vercel.app

# Cloudinary (recommended). If omitted, files save to ./uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public URL of this API (file links / uploads). On Render use your service URL, e.g.:
# PUBLIC_API_URL=https://attendence-app-jlgs.onrender.com
PUBLIC_API_URL=http://localhost:5000
