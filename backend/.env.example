# Server (Render sets PORT)
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/attendance?retryWrites=true&w=majority

JWT_SECRET=use-a-long-random-string-in-production

# Comma-separated origins (Vercel preview + production)
CLIENT_URL=http://localhost:5173

# Cloudinary (recommended). If omitted, files save to ./uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Local fallback public URL (dev: http://localhost:5000)
PUBLIC_API_URL=http://localhost:5000
